
module load Miniconda3/23.3.1-0 || module load miniconda3/23.5.2-0 
eval "$(conda shell.bash hook)"

conda create -p ${PLG_GROUPS_STORAGE}/plggmeetween/envs/conda/speechmos -c conda-forge pip python=3.9
conda activate  ${PLG_GROUPS_STORAGE}/plggmeetween/envs/conda/speechmos 

