module load Miniconda3/23.3.1-0
eval "$(conda shell.bash hook)"

conda create -p ${PLG_GROUPS_STORAGE}/plggmeetween/envs/conda/bleurt -c conda-forge pip
conda activate  ${PLG_GROUPS_STORAGE}/plggmeetween/envs/conda/bleurt 


git clone https://github.com/google-research/bleurt.git
cd bleurt
pip install .

cd ..
rm -rf bleurt

pip install tensorflow[and-cuda]


